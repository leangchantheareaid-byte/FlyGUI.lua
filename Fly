-- ==========================================
-- 2. Core Detection Logic
-- ==========================================
local autoParry = false
local remotes = ReplicatedStorage:WaitForChild("Remotes")
local parryRemote = remotes:FindFirstChild("ParryAttempt") or remotes:FindFirstChild("Block")

local function getBall()
    for _, obj in pairs(workspace:GetChildren()) do
        if obj:GetAttribute("realBall") == true then
            return obj
        end
    end
    return nil
end

parryBtn.MouseButton1Click:Connect(function()
    autoParry = not autoParry
    parryBtn.Text = autoParry and "Parry: ENABLED" or "Parry: DISABLED"
    parryBtn.BackgroundColor3 = autoParry and Color3.fromRGB(60, 180, 60) or Color3.fromRGB(40, 40, 40)
end)

RunService.Heartbeat:Connect(function()
    if not autoParry then return end
    
    local ball = getBall()
    if ball and ball:GetAttribute("target") == player.Name then
        local distance = (ball.Position - rootPart.Position).Magnitude
        local velocity = ball.AssemblyLinearVelocity.Magnitude
        
        -- The Magic Math: If it hits in less than 0.6 seconds, block!
        if (distance / velocity) <= 0.6 then
            if parryRemote then
                parryRemote:FireServer()
            end
        end
    end
end)
